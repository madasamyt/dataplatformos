{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dataplatformos.dev/schemas/data_product.v1.schema.json",
  "title": "DataProduct",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "delivery/v1" },
    "kind": { "const": "DataProduct" },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "owner": { "type": "string" },
        "description": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "owningDomain", "productType", "source", "certification"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Human-friendly marketplace listing name"
        },
        "owningDomain": {
          "type": "string",
          "minLength": 1,
          "description": "Consumption-level domain (D6), not source system domain"
        },
        "productType": {
          "type": "string",
          "enum": ["foundation", "analytical", "360", "aiml", "kpi", "dashboard"]
        },
        "source": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "ref"],
          "properties": {
            "kind": {
              "type": "string",
              "enum": ["silver", "gold", "semantic", "metric"]
            },
            "ref": {
              "type": "string",
              "minLength": 1,
              "description": "Table/view/metric id content is certified from"
            }
          }
        },
        "metricRef": {
          "type": "string",
          "description": "Required for kpi/dashboard when a governed reusable metric is involved (D4/D7)"
        },
        "certification": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "version"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["certified", "provisional", "draft"]
            },
            "version": { "type": "string", "minLength": 1 },
            "certifiedBy": { "type": "string" },
            "notes": { "type": "string" }
          }
        },
        "sla": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "freshness": { "type": "string" },
            "completeness": { "type": "string" },
            "correctedWithin": {
              "type": "string",
              "description": "For provisional streaming products, e.g. PT4H"
            }
          }
        },
        "outputPorts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["type"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["sql", "api", "rest", "graphql", "bi", "file", "stream", "mcp"]
              },
              "name": { "type": "string" },
              "endpoint": { "type": "string" }
            }
          }
        },
        "dependsOn": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Upstream table/pipeline/product ids for lineage-aware re-certification (D11)"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "productType": { "enum": ["kpi", "dashboard"] }
            },
            "required": ["productType"]
          },
          "then": {
            "required": ["metricRef"]
          }
        },
        {
          "if": {
            "properties": {
              "certification": {
                "properties": { "status": { "const": "provisional" } },
                "required": ["status"]
              }
            },
            "required": ["certification"]
          },
          "then": {
            "properties": {
              "sla": { "required": ["correctedWithin"] }
            }
          }
        }
      ]
    }
  }
}
