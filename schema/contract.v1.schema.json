{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dataplatformos.dev/schemas/contract.v1.schema.json",
  "title": "Contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "contract/v1" },
    "kind": { "const": "Contract" },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "description": { "type": "string" }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attributes"],
      "properties": {
        "attributes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/attribute" }
        }
      }
    }
  },
  "$defs": {
    "attribute": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "minLength": 1 },
        "nullable": { "type": "boolean" },
        "accepted_values": {
          "type": "array",
          "items": { "type": ["string", "number", "boolean"] }
        },
        "valid_range": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "min": { "type": "number" },
            "max": { "type": "number" }
          }
        },
        "derived_from": {
          "oneOf": [
            { "type": "string" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["semantic_ref"],
              "properties": {
                "semantic_ref": { "type": "string", "minLength": 1 }
              }
            }
          ]
        }
      }
    }
  }
}
