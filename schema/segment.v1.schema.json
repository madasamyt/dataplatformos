{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dataplatformos.dev/schemas/segment.v1.schema.json",
  "title": "Segment",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "platform/v1" },
    "kind": { "const": "Segment" },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "domain": { "type": "string" },
        "owner": { "type": "string" },
        "description": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pipelines"],
      "properties": {
        "landingSpaces": {
          "type": "array",
          "items": { "$ref": "#/$defs/landingSpace" }
        },
        "pipelines": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["ref"],
            "properties": {
              "ref": { "type": "string", "minLength": 1 }
            }
          }
        },
        "metrics": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["ref"],
            "properties": {
              "ref": { "type": "string", "minLength": 1 }
            }
          }
        },
        "products": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["ref"],
            "properties": {
              "ref": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "landingSpace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "mode"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "mode": {
          "type": "string",
          "enum": ["platform_owned", "tool_managed", "source_owned"]
        },
        "storageRef": { "type": "string", "minLength": 1 }
      },
      "allOf": [
        {
          "if": {
            "properties": { "mode": { "const": "platform_owned" } },
            "required": ["mode"]
          },
          "then": { "required": ["storageRef"] }
        },
        {
          "if": {
            "properties": {
              "mode": { "enum": ["tool_managed", "source_owned"] }
            },
            "required": ["mode"]
          },
          "then": {
            "not": { "required": ["storageRef"] }
          }
        }
      ]
    }
  }
}
